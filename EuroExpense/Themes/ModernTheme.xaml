<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ✨ MODERN CLEAN THEME -->
    <!-- Light professional aesthetic with subtle grays -->
    
    <!-- ========== COLOR PALETTE ========== -->
    
    <!-- Background Colors -->
    <Color x:Key="AppBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceHoverColor">#F5F5F5</Color>
    <Color x:Key="SurfaceActiveColor">#E6E6E6</Color>
    
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="SurfaceActiveBrush" Color="{StaticResource SurfaceActiveColor}"/>
    
    <!-- Accent Colors -->
    <Color x:Key="AccentMintColor">#171717</Color>
    <Color x:Key="AccentVioletColor">#171717</Color>
    <Color x:Key="AccentHoverColor">#0A0A0A</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    
    <SolidColorBrush x:Key="AccentMintBrush" Color="{StaticResource AccentMintColor}"/>
    <SolidColorBrush x:Key="AccentVioletBrush" Color="{StaticResource AccentVioletColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    
    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#0A0A0A</Color>
    <Color x:Key="TextSecondaryColor">#737373</Color>
    <Color x:Key="TextTertiaryColor">#A1A1A1</Color>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    
    <!-- Border & Divider -->
    <Color x:Key="BorderColor">#E6E6E6</Color>
    <Color x:Key="DividerColor">#E6E6E6</Color>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    
    <!-- ========== TYPOGRAPHY ========== -->
    
    <!-- Font Families -->
    <!-- JetBrains Mono as primary font with fallbacks -->
    <FontFamily x:Key="PrimaryFont">JetBrains Mono, Consolas, Segoe UI, system-ui, Arial</FontFamily>
    <!-- JetBrains Mono as monospace font with fallbacks -->
    <FontFamily x:Key="MonoFont">JetBrains Mono, Consolas, SF Mono, Monaco, Courier New</FontFamily>
    
    <!-- Font Sizes -->
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize10">10</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize11">11</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize12">12</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize13">13</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize14">14</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize16">16</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize18">18</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize20">20</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize24">24</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize32">32</System:Double>
    
    <!-- ========== SPACING & SIZING ========== -->
    
    <!-- Corner Radius -->
    <CornerRadius x:Key="RadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">16</CornerRadius>
    
    <!-- Spacing -->
    <Thickness x:Key="Spacing4">4</Thickness>
    <Thickness x:Key="Spacing8">8</Thickness>
    <Thickness x:Key="Spacing12">12</Thickness>
    <Thickness x:Key="Spacing16">16</Thickness>
    <Thickness x:Key="Spacing24">24</Thickness>
    <Thickness x:Key="Spacing32">32</Thickness>
    
    <!-- ========== EFFECTS ========== -->
    
    <!-- Soft Card Shadow -->
    <DropShadowEffect x:Key="CardShadow" 
                      Color="#00000040" 
                      BlurRadius="20" 
                      ShadowDepth="0" 
                      Opacity="0.5"/>
    
    <!-- Mint Glow Effect -->
    <DropShadowEffect x:Key="GlowMint" 
                      Color="{StaticResource AccentMintColor}" 
                      BlurRadius="20" 
                      ShadowDepth="0" 
                      Opacity="0.4"/>
    
    <!-- Violet Glow Effect -->
    <DropShadowEffect x:Key="GlowViolet" 
                      Color="{StaticResource AccentVioletColor}" 
                      BlurRadius="20" 
                      ShadowDepth="0" 
                      Opacity="0.4"/>
    
    <!-- ========== COMPONENT STYLES ========== -->
    
    <!-- Dashboard Card Style -->
    <Style x:Key="DashboardCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Stats Card Style (for summary cards) -->
    <Style x:Key="StatsCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Primary Button Style (dark button with white text) -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentMintBrush}"/>
        <Setter Property="Foreground" Value="#FAFAFA"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize13}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                           CornerRadius="{StaticResource RadiusMedium}"
                           Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Secondary Button Style -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize13}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           CornerRadius="{StaticResource RadiusMedium}"
                           Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentMintBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Danger Button (for Delete - red accent) -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#EF4444"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground">
            <Setter.Value>
                <SolidColorBrush Color="#EF4444"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#EF4444" Opacity="0.1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="#DC2626"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Icon Button (square button for icons) -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           CornerRadius="8"
                           Padding="0">
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentMintBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Text Input Style -->
    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize13}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           CornerRadius="{StaticResource RadiusMedium}">
                        <ScrollViewer x:Name="PART_ContentHost" 
                                     Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentMintBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- ComboBox Style -->
    <Style x:Key="ModernComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize13}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- DatePicker Style -->
    <Style x:Key="ModernDatePicker" TargetType="DatePicker">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize13}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Modern DataGrid Style -->
    <Style x:Key="ModernDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="RowHeight" Value="48"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize13}"/>
        <Setter Property="ColumnHeaderHeight" Value="44"/>
    </Style>
    
    <!-- DataGrid Column Header -->
    <Style x:Key="ModernDataGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#000000"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    
    <!-- DataGrid Row -->
    <Style x:Key="ModernDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="MinHeight" Value="50"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.3"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="{StaticResource AccentMintColor}" Opacity="0.1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- DataGrid Cell -->
    <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" 
                           Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Label Style -->
    <Style x:Key="ModernLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize12}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>
    
    <!-- Heading Styles -->
    <Style x:Key="Heading1" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize24}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Typography.Capitals" Value="Normal"/>
    </Style>
    
    <Style x:Key="Heading2" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize18}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <Style x:Key="Heading3" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize16}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <!-- Stats Number Style -->
    <Style x:Key="StatsNumber" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize24}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <!-- Stats Label Style -->
    <!-- Stats Label Style (use uppercase text in XAML manually) -->
    <Style x:Key="StatsLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <!-- Stats Value Style -->
    <Style x:Key="StatsValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize24}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <!-- Body Text Style -->
    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSize13}"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>
    
    <!-- ========== SCROLLBAR STYLES ========== -->
    
    <!-- ScrollBar RepeatButton (Arrows - Hidden for modern look) -->
    <Style x:Key="ScrollBarRepeatButton" TargetType="RepeatButton">
        <Setter Property="Width" Value="0"/>
        <Setter Property="Height" Value="0"/>
        <Setter Property="Visibility" Value="Collapsed"/>
    </Style>
    
    <!-- ScrollBar Thumb -->
    <Style x:Key="ScrollBarThumb" TargetType="Thumb">
        <Setter Property="Background" Value="#D1D1D1"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}"
                           CornerRadius="3"
                           Width="6"
                           Margin="1,0"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#A1A1A1"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter Property="Background" Value="#737373"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Vertical ScrollBar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="MinWidth" Value="8"/>
        <Setter Property="Background" Value="#F5F5F5"/>
        <Setter Property="Foreground" Value="#D1D1D1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="#F5F5F5" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Up Button (Hidden) -->
                            <RepeatButton Grid.Row="0"
                                         Style="{StaticResource ScrollBarRepeatButton}"
                                         Command="ScrollBar.LineUpCommand"/>
                            
                            <!-- Track -->
                            <Track x:Name="PART_Track" 
                                  Grid.Row="1"
                                  IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                Opacity="0"
                                                Background="Transparent"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                Opacity="0"
                                                Background="Transparent"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            
                            <!-- Down Button (Hidden) -->
                            <RepeatButton Grid.Row="2"
                                         Style="{StaticResource ScrollBarRepeatButton}"
                                         Command="ScrollBar.LineDownCommand"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- Horizontal ScrollBar Override -->
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="MinHeight" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="#F5F5F5" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left Button (Hidden) -->
                                    <RepeatButton Grid.Column="0"
                                                 Style="{StaticResource ScrollBarRepeatButton}"
                                                 Command="ScrollBar.LineLeftCommand"/>
                                    
                                    <!-- Track -->
                                    <Track x:Name="PART_Track" 
                                          Grid.Column="1"
                                          IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                        Opacity="0"
                                                        Background="Transparent"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{TemplateBinding Background}"
                                                               CornerRadius="3"
                                                               Height="6"
                                                               Margin="0,1"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand"
                                                        Opacity="0"
                                                        Background="Transparent"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    
                                    <!-- Right Button (Hidden) -->
                                    <RepeatButton Grid.Column="2"
                                                 Style="{StaticResource ScrollBarRepeatButton}"
                                                 Command="ScrollBar.LineRightCommand"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
    
</ResourceDictionary>
