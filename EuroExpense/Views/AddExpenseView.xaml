<Window x:Class="EuroExpense.Views.AddExpenseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add Expense" SizeToContent="Height" Width="500" MaxWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" 
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource PrimaryFont}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">
    <Window.Resources>
        <!-- Custom Hint Color -->
        <SolidColorBrush x:Key="CustomHintBrush" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="MaterialDesignTextFieldBoxHoverBackground" Color="#F5F5F5"/>
        
        <!-- Custom Input Style with Light Placeholder -->
        <Style x:Key="CustomTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#B3B3B3"/>
            <Setter Property="materialDesign:TextFieldAssist.TextBoxViewMargin" Value="0"/>
            <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="10"/>
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="#4A4A4A"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4A4A4A"/>
                    <Setter Property="BorderThickness" Value="0.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#CFCFCF" BlurRadius="2" ShadowDepth="0" Opacity="1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="CustomComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#B3B3B3"/>
            <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="10"/>
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="#4A4A4A"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#4A4A4A"/>
                    <Setter Property="BorderThickness" Value="0.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#CFCFCF" BlurRadius="2" ShadowDepth="0" Opacity="1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Custom ComboBox Item Style -->
        <Style x:Key="CustomComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="CustomDatePicker" TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#B3B3B3"/>
            <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="10"/>
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="#4A4A4A"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#4A4A4A"/>
                    <Setter Property="BorderThickness" Value="0.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#CFCFCF" BlurRadius="2" ShadowDepth="0" Opacity="1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Save Button Style - Same as Add Expense Button -->
        <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="#171717"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="37"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E2E2E"/>
                    <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Cancel Button Style - No Blue Border -->
        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Height" Value="37"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="Foreground" Value="#0A0A0A"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource AppBackgroundBrush}" 
            CornerRadius="10" 
            BorderThickness="1" 
            BorderBrush="#E0E0E0">
        <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Close Button -->
        <Button Command="{Binding CancelCommand}"
               Grid.Row="0"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Background="Transparent"
               BorderThickness="0"
               Padding="8"
               Width="32"
               Height="32"
               Margin="0,-4,0,0"
               Cursor="Hand"
               Panel.ZIndex="1">
            <TextBlock Text="✕" FontSize="18" Foreground="#737373"/>
        </Button>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24" MouseLeftButtonDown="Header_MouseLeftButtonDown" Background="Transparent">
            <StackPanel>
                <TextBlock Text="Add New Expense" 
                          Style="{StaticResource Heading2}"
                          FontSize="24"
                          FontWeight="Bold"/>
                <TextBlock Text="Fill in the details below" 
                          Style="{StaticResource BodyText}"
                          Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Form -->
        <StackPanel Grid.Row="1">
                <!-- Amount -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Amount" 
                              FontSize="13" 
                              FontWeight="Medium" 
                              Foreground="{StaticResource TextPrimaryBrush}" 
                              Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" 
                            Style="{StaticResource CustomTextBox}"
                            materialDesign:HintAssist.Hint="€ 0.00"
                            materialDesign:HintAssist.IsFloating="False"
                            Foreground="#0A0A0A"
                            Height="40"
                            Padding="12,8"
                            VerticalContentAlignment="Center"
                            FontSize="14"/>
                </StackPanel>

                <!-- Category -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Category" 
                              FontSize="13" 
                              FontWeight="Medium" 
                              Foreground="{StaticResource TextPrimaryBrush}" 
                              Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Categories}" 
                             SelectedValue="{Binding SelectedCategoryId}"
                             SelectedValuePath="Id"
                             DisplayMemberPath="Name"
                             Style="{StaticResource CustomComboBox}"
                             ItemContainerStyle="{StaticResource CustomComboBoxItem}"
                             materialDesign:HintAssist.Hint="Select a category"
                             materialDesign:HintAssist.IsFloating="False"
                             Foreground="#0A0A0A"
                             Height="40"
                             Padding="12,8"
                             VerticalContentAlignment="Center"
                             FontSize="14"/>
                </StackPanel>

                <!-- Description -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Description" 
                              FontSize="13" 
                              FontWeight="Medium" 
                              Foreground="{StaticResource TextPrimaryBrush}" 
                              Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                            Style="{StaticResource CustomTextBox}"
                            materialDesign:HintAssist.Hint="What did you spend on?"
                            materialDesign:HintAssist.IsFloating="False"
                            Foreground="#0A0A0A"
                            Height="40"
                            Padding="12,8"
                            VerticalContentAlignment="Center"
                            FontSize="14"/>
                </StackPanel>

                <!-- Payment Method -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Payment Method" 
                              FontSize="13" 
                              FontWeight="Medium" 
                              Foreground="{StaticResource TextPrimaryBrush}" 
                              Margin="0,0,0,8"/>
                    <ComboBox SelectedItem="{Binding PaymentMethod}" 
                             Style="{StaticResource CustomComboBox}"
                             ItemContainerStyle="{StaticResource CustomComboBoxItem}"
                             materialDesign:HintAssist.Hint="Select payment method"
                             materialDesign:HintAssist.IsFloating="False"
                             Foreground="#0A0A0A"
                             Height="40"
                             Padding="12,8"
                             VerticalContentAlignment="Center"
                             FontSize="14">
                        <sys:String>Cash</sys:String>
                        <sys:String>Credit Card</sys:String>
                        <sys:String>Debit Card</sys:String>
                        <sys:String>UPI</sys:String>
                        <sys:String>Net Banking</sys:String>
                    </ComboBox>
                </StackPanel>
        </StackPanel>

        <!-- Action Buttons -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0"
                   Command="{Binding CancelCommand}"
                   Style="{StaticResource CancelButtonStyle}"
                   Padding="24,0"
                   HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="✕" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Cancel" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            
            <Button Grid.Column="2"
                   Command="{Binding SaveCommand}"
                   Style="{StaticResource SaveButtonStyle}"
                   Padding="24,0"
                   HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Save Expense" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
        </Grid>
    </Border>
</Window>
