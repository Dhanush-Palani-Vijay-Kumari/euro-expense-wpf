<Window x:Class="EuroExpense.Views.BudgetView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Budget Manager" Height="780" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" 
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource PrimaryFont}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">
    <Window.Resources>
        <!-- Stat Card Style -->
        <Style x:Key="StatCardStyle" TargetType="materialDesign:Card">
            <Setter Property="UniformCornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#88171717"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Budget Card Style -->
        <Style x:Key="BudgetCardStyle" TargetType="materialDesign:Card">
            <Setter Property="UniformCornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#88171717"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="#171717"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E2E2E"/>
                    <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Input Style -->
        <Style x:Key="BudgetInput" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#B3B3B3"/>
            <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="10"/>
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="#4A4A4A"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#4A4A4A"/>
                    <Setter Property="BorderThickness" Value="0.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#CFCFCF" BlurRadius="2" ShadowDepth="0" Opacity="1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="BudgetComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#B3B3B3"/>
            <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="10"/>
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="#4A4A4A"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#4A4A4A"/>
                    <Setter Property="BorderThickness" Value="0.5"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#CFCFCF" BlurRadius="2" ShadowDepth="0" Opacity="1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource AppBackgroundBrush}" 
            CornerRadius="10" 
            BorderThickness="1" 
            BorderBrush="#E0E0E0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Fixed Header Navbar -->
            <Grid Grid.Row="0" 
                  Background="{StaticResource AppBackgroundBrush}" 
                  Margin="40,24,40,0"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#0A0A0A">
                        <Run Text="Budget"/>
                        <Run Text="Manager" Foreground="#171717"/>
                    </TextBlock>
                </StackPanel>
                
                <!-- Close Button -->
                <Button Command="{Binding CancelCommand}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Background="Transparent"
                       BorderThickness="0"
                       Padding="8"
                       Width="32"
                       Height="32"
                       Cursor="Hand">
                    <TextBlock Text="✕" FontSize="18" Foreground="#737373"/>
                </Button>
            </Grid>

            <!-- Scrollable Content -->
            <ScrollViewer Grid.Row="1" 
                         VerticalScrollBarVisibility="Auto" 
                         Margin="40,32,40,40">
                <StackPanel>

                    <!-- Stat Cards -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Budget Card -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Total Budget" 
                                      FontSize="13" 
                                      Foreground="#8F8F8F" 
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalBudget, StringFormat='€{0:N2}'}" 
                                      FontSize="30" 
                                      FontWeight="Bold" 
                                      Foreground="#0A0A0A"/>
                            <TextBlock Text="Monthly allocation" 
                                      FontSize="12" 
                                      Foreground="#8F8F8F" 
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Total Spent Card -->
                    <materialDesign:Card Grid.Column="2" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Total Spent" 
                                      FontSize="13" 
                                      Foreground="#8F8F8F" 
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TotalSpent, StringFormat='€{0:N2}'}" 
                                      FontSize="30" 
                                      FontWeight="Bold" 
                                      Foreground="#EF4444"/>
                            <TextBlock FontSize="12" 
                                      Foreground="#8F8F8F" 
                                      Margin="0,8,0,0">
                                <Run Text="{Binding TotalPercentage, StringFormat='{}{0:F1}%', Mode=OneWay}"/>
                                <Run Text=" of budget"/>
                            </TextBlock>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Remaining Card -->
                    <materialDesign:Card Grid.Column="4" Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Remaining" 
                                      FontSize="13" 
                                      Foreground="#8F8F8F" 
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding RemainingBudget, StringFormat='€{0:N2}'}" 
                                      FontSize="30" 
                                      FontWeight="Bold" 
                                      Foreground="#009689"/>
                            <TextBlock Text="Available to spend" 
                                      FontSize="12" 
                                      Foreground="#8F8F8F" 
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Create New Budget Card -->
                <materialDesign:Card Style="{StaticResource BudgetCardStyle}" Margin="0,0,0,32">
                    <StackPanel>
                        <TextBlock Text="Create New Budget" 
                                  FontSize="18" 
                                  FontWeight="SemiBold" 
                                  Foreground="#0A0A0A" 
                                  Margin="0,0,0,20"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Category Dropdown -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Category" 
                                          FontSize="13" 
                                          Foreground="#0A0A0A" 
                                          Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding AvailableCategories}"
                                         SelectedItem="{Binding SelectedCategory}"
                                         Style="{StaticResource BudgetComboBox}"
                                         materialDesign:HintAssist.Hint="Select category"
                                         materialDesign:HintAssist.IsFloating="False"/>
                            </StackPanel>

                            <!-- Amount Input -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Amount" 
                                          FontSize="13" 
                                          Foreground="#0A0A0A" 
                                          Margin="0,0,0,8"/>
                                <TextBox Text="{Binding NewBudgetAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                        Style="{StaticResource BudgetInput}"
                                        materialDesign:HintAssist.Hint="€ 0.00"
                                        materialDesign:HintAssist.IsFloating="False"/>
                            </StackPanel>

                            <!-- Period Dropdown -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Period" 
                                          FontSize="13" 
                                          Foreground="#0A0A0A" 
                                          Margin="0,0,0,8"/>
                                <ComboBox SelectedItem="{Binding SelectedPeriod}"
                                         Style="{StaticResource BudgetComboBox}">
                                    <ComboBoxItem Content="Monthly" IsSelected="True"/>
                                    <ComboBoxItem Content="Weekly"/>
                                    <ComboBoxItem Content="Yearly"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Add Button -->
                            <Button Grid.Column="6"
                                   Command="{Binding AddBudgetCommand}"
                                   Style="{StaticResource PrimaryButton}"
                                   VerticalAlignment="Bottom"
                                   Padding="20,0"
                                   MinWidth="120">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" 
                                                           Width="18" 
                                                           Height="18" 
                                                           Margin="0,0,8,0"/>
                                    <TextBlock Text="Add Budget" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Your Budgets Section -->
                <TextBlock Text="Your Budgets" 
                          FontSize="18" 
                          FontWeight="SemiBold" 
                          Foreground="#0A0A0A" 
                          Margin="0,0,0,16"/>

                <!-- Budget Cards List -->
                <ItemsControl ItemsSource="{Binding CategoryBudgets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Style="{StaticResource BudgetCardStyle}">
                                <StackPanel>
                                    <!-- Header Row -->
                                    <Grid Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Color Indicator -->
                                            <Ellipse Width="12" 
                                                    Height="12" 
                                                    Fill="{Binding CategoryColor}" 
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Center"/>
                                            
                                            <StackPanel>
                                                <TextBlock Text="{Binding CategoryName}" 
                                                          FontSize="16" 
                                                          FontWeight="SemiBold" 
                                                          Foreground="#0A0A0A"/>
                                                <TextBlock Text="{Binding Period, StringFormat='{}{0} budget'}" 
                                                          FontSize="12" 
                                                          Foreground="#8F8F8F"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Delete Button -->
                                        <Button Command="{Binding DataContext.DeleteBudgetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding}"
                                               HorizontalAlignment="Right"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Padding="8"
                                               Width="36"
                                               Height="36"
                                               Cursor="Hand">
                                            <materialDesign:PackIcon Kind="DeleteOutline" 
                                                                   Width="18" 
                                                                   Height="18" 
                                                                   Foreground="#8F8F8F"/>
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>

                                    <!-- Progress Section -->
                                    <StackPanel Margin="0,0,0,16">
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock FontSize="13" Foreground="#8F8F8F">
                                                <Run Text="€"/>
                                                <Run Text="{Binding Spent, StringFormat='{}{0:N2}', Mode=OneWay}"/>
                                                <Run Text=" of €"/>
                                                <Run Text="{Binding BudgetLimit, StringFormat='{}{0:N2}', Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding PercentageUsed, StringFormat='{}{0:F1}%', Mode=OneWay}"
                                                      FontSize="13"
                                                      FontWeight="Medium"
                                                      Foreground="#0A0A0A"
                                                      HorizontalAlignment="Right"/>
                                        </Grid>
                                        
                                        <!-- Progress Bar -->
                                        <ProgressBar Value="{Binding PercentageUsed, Mode=OneWay}" 
                                                    Minimum="0" 
                                                    Maximum="100"
                                                    Height="8"
                                                    Foreground="{Binding ProgressBarColor, Mode=OneWay}"
                                                    Background="#E5E5E5"
                                                    BorderThickness="0"/>
                                    </StackPanel>

                                    <!-- Editable Fields -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Budget Amount -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Budget Amount" 
                                                      FontSize="12" 
                                                      Foreground="#0A0A0A" 
                                                      Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding BudgetLimit, UpdateSourceTrigger=PropertyChanged, StringFormat='N2'}"
                                                    Style="{StaticResource BudgetInput}"
                                                    Height="36"
                                                    Padding="10,6"
                                                    VerticalContentAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Amount Spent -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Amount Spent" 
                                                      FontSize="12" 
                                                      Foreground="#0A0A0A" 
                                                      Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Spent, Mode=OneWay, StringFormat='N2'}"
                                                    Style="{StaticResource BudgetInput}"
                                                    Height="36"
                                                    Padding="10,6"
                                                    VerticalContentAlignment="Center"
                                                    IsReadOnly="True"
                                                    Background="#F5F5F5"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
