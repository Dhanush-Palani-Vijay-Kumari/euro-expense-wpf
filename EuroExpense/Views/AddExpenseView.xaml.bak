<Window x:Class="EuroExpense.Views.AddExpenseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add Expense" Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}" 
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="480"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource PrimaryFont}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">
    <Window.Resources>
        <!-- Save Button Style - Same as Add Expense Button -->
        <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="#171717"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="37"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E2E2E"/>
                    <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Cancel Button Style - No Blue Border -->
        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Height" Value="37"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Add New Expense" 
                      Style="{StaticResource Heading2}"/>
            <TextBlock Text="Fill in the details below" 
                      Style="{StaticResource BodyText}"
                      Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <materialDesign:Card Padding="32" UniformCornerRadius="12" 
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                materialDesign:ElevationAssist.Elevation="Dp0"
                                Margin="0,0,0,16">
                <StackPanel>
                <!-- Amount -->
                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" 
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        materialDesign:HintAssist.Hint="Amount *"
                        FontSize="14"
                        Margin="0,0,0,20"/>

                <!-- Category -->
                <ComboBox ItemsSource="{Binding Categories}" 
                         SelectedValue="{Binding SelectedCategoryId}"
                         SelectedValuePath="Id"
                         DisplayMemberPath="Name"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         materialDesign:HintAssist.Hint="Category *"
                         FontSize="14"
                         Margin="0,0,0,20"/>

                <!-- Description -->
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        materialDesign:HintAssist.Hint="Description"
                        Height="100" 
                        TextWrapping="Wrap" 
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto"
                        FontSize="14"
                        Margin="0,0,0,20"/>

                <!-- Date -->
                <DatePicker SelectedDate="{Binding Date}" 
                           Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                           materialDesign:HintAssist.Hint="Date *"
                           FontSize="14"
                           Margin="0,0,0,20"/>

                <!-- Payment Method -->
                <ComboBox Text="{Binding PaymentMethod}" 
                         IsEditable="True"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         materialDesign:HintAssist.Hint="Payment Method"
                         FontSize="14">
                    <ComboBoxItem Content="Cash"/>
                    <ComboBoxItem Content="Credit Card"/>
                    <ComboBoxItem Content="Debit Card"/>
                    <ComboBoxItem Content="UPI"/>
                    <ComboBoxItem Content="Net Banking"/>
                </ComboBox>
                </StackPanel>
            </materialDesign:Card>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right" 
                   Margin="0,24,0,0">
            <Button Command="{Binding CancelCommand}"
                   Style="{StaticResource CancelButtonStyle}"
                   Padding="24,0"
                   Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✕" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Cancel" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCommand}"
                   Style="{StaticResource SaveButtonStyle}"
                   Padding="24,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✓" FontSize="18" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Save Expense" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
