<Window x:Class="EuroExpense.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:EuroExpense.Helpers"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Expense Tracker" Height="850" Width="1360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{StaticResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource PrimaryFont}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">
    <Window.Resources>
        <helpers:TextLengthToVisibilityConverter x:Key="TextLengthToVisibilityConverter"/>
        <DropShadowEffect x:Key="DashboardCardShadow"
                           Color="#000000"
                           Opacity="0.06"
                           BlurRadius="10"
                           ShadowDepth="2"
                           Direction="270"/>
        
        <!-- Custom Add Expense Button Style - No Shadow on Hover, Reduced Contrast -->
        <Style x:Key="AddExpenseButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="#171717"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="37"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E2E2E"/>
                    <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Custom Outlined Button Style - No Blue Border -->
        <Style x:Key="OutlinedButtonNoBorder" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Minimal ContextMenu Style -->
        <Style x:Key="MinimalContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" 
                                                Opacity="0.08" 
                                                ShadowDepth="2" 
                                                BlurRadius="12"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Minimal MenuItem Style -->
        <Style x:Key="MinimalMenuItem" TargetType="MenuItem">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#0A0A0A"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="6"
                                Margin="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                ContentSource="Icon"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1"
                                                ContentSource="Header"
                                                VerticalAlignment="Center"
                                                Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Segmented Button Base Style -->
        <Style x:Key="SegmentedButtonBase" TargetType="Button">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#737373"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="37"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E8E8E8"/>
                                <Setter Property="Foreground" Value="#0A0A0A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#DEDEDE"/>
                                <Setter Property="Foreground" Value="#111111"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Segmented Button Left -->
        <Style x:Key="SegmentedButtonLeft" TargetType="Button" BasedOn="{StaticResource SegmentedButtonBase}">
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- Segmented Button Middle -->
        <Style x:Key="SegmentedButtonMiddle" TargetType="Button" BasedOn="{StaticResource SegmentedButtonBase}">
            <Setter Property="Tag" Value="0"/>
            <Setter Property="BorderThickness" Value="1,1,0,1"/>
        </Style>
        
        <!-- Segmented Button Right -->
        <Style x:Key="SegmentedButtonRight" TargetType="Button" BasedOn="{StaticResource SegmentedButtonBase}">
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- Clean ComboBoxItem Style -->
        <Style x:Key="CleanComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0A0A0A"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter 
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Clean ComboBox Style with Reduced Shadow -->
        <Style x:Key="CleanComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid Margin="32,42,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Stats Cards -->
            <RowDefinition Height="Auto"/>   <!-- Filters -->
            <RowDefinition Height="*"/>      <!-- Table -->
            <RowDefinition Height="Auto"/>   <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Grid Grid.Row="0" Margin="0,0,0,32" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <StackPanel>
                <TextBlock Text="EuroExpense" Style="{StaticResource Heading1}"/>
                <TextBlock Text="Track and manage your expenses efficiently" 
                          Foreground="{StaticResource TextSecondaryBrush}" 
                          FontSize="14" 
                          Margin="0,4,0,0"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Segmented Button Group -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <Button Command="{Binding ShowBudgetCommand}"
                           Style="{StaticResource SegmentedButtonLeft}"
                           Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="WalletOutline" 
                                                    Width="16" 
                                                    Height="16" 
                                                    Margin="0,0,6,0" 
                                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Budget" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowReportsCommand}"
                           Style="{StaticResource SegmentedButtonRight}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar" 
                                                    Width="16" 
                                                    Height="16" 
                                                    Margin="0,0,6,0" 
                                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Reports" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Primary CTA -->
                <Button Command="{Binding AddExpenseCommand}"
                       Style="{StaticResource AddExpenseButtonStyle}"
                       Padding="20,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" 
                                                           Width="18" 
                                                           Height="18" 
                                                           Margin="0,0,8,0"/>
                        <TextBlock Text="Add Expense" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button Width="32"
                    Height="32"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-30,-15,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Panel.ZIndex="2"
                    Click="CloseButton_Click">
                <TextBlock Text="✕" FontSize="16" Foreground="#737373"/>
            </Button>
        </Grid>

        <!-- ========== STATS CARDS ========== -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Expenses -->
            <materialDesign:Card Grid.Column="0" 
                                Margin="0,0,12,0" 
                                Padding="20"
                                Effect="{StaticResource DashboardCardShadow}"
                                UniformCornerRadius="8"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                materialDesign:ElevationAssist.Elevation="Dp0">
                <StackPanel>
                    <TextBlock Text="Total Expenses" Style="{StaticResource StatsLabel}"/>
                    <TextBlock Text="{Binding TotalExpenses, StringFormat=€{0:N0}}" 
                              FontSize="28"
                              FontWeight="Bold"
                              Foreground="{StaticResource AccentMintBrush}"
                              Margin="0,8,0,0"/>
                    <TextBlock Text="+12.5%" 
                              FontSize="12"
                              Foreground="#10B981"
                              Margin="0,4,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- This Month -->
            <materialDesign:Card Grid.Column="1" 
                                Margin="0,0,12,0" 
                                Padding="20"
                                Effect="{StaticResource DashboardCardShadow}"
                                UniformCornerRadius="8"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                materialDesign:ElevationAssist.Elevation="Dp0">
                <StackPanel>
                    <TextBlock Text="This Month" Style="{StaticResource StatsLabel}"/>
                    <TextBlock Text="{Binding MonthlyTotal, StringFormat=€{0:N0}}" 
                              FontSize="28"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,8,0,0"/>
                    <TextBlock Text="+8.2%" 
                              FontSize="12"
                              Foreground="#10B981"
                              Margin="0,4,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Last 7 Days -->
            <materialDesign:Card Grid.Column="2" 
                                Margin="0,0,12,0" 
                                Padding="20"
                                Effect="{StaticResource DashboardCardShadow}"
                                UniformCornerRadius="8"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                materialDesign:ElevationAssist.Elevation="Dp0">
                <StackPanel>
                    <TextBlock Text="Last 7 Days" Style="{StaticResource StatsLabel}"/>
                    <TextBlock Text="{Binding WeeklyTotal, StringFormat=€{0:N0}}" 
                              FontSize="28"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,8,0,0"/>
                    <TextBlock Text="-3.1%" 
                              FontSize="12"
                              Foreground="#EF4444"
                              Margin="0,4,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Average Daily -->
            <materialDesign:Card Grid.Column="3" 
                                Margin="0,0,12,0" 
                                Padding="20"
                                Effect="{StaticResource DashboardCardShadow}"
                                UniformCornerRadius="8"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                materialDesign:ElevationAssist.Elevation="Dp0">
                <StackPanel>
                    <TextBlock Text="AVG Daily" Style="{StaticResource StatsLabel}"/>
                    <TextBlock Text="{Binding AverageDaily, StringFormat=€{0:N0}}" 
                              FontSize="28"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,8,0,0"/>
                    <TextBlock Text="+5.7%" 
                              FontSize="12"
                              Foreground="#10B981"
                              Margin="0,4,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Top Category -->
            <materialDesign:Card Grid.Column="4" 
                                Padding="20"
                                Effect="{StaticResource DashboardCardShadow}"
                                UniformCornerRadius="8"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                materialDesign:ElevationAssist.Elevation="Dp0">
                <StackPanel>
                    <TextBlock Text="Top Category" Style="{StaticResource StatsLabel}"/>
                    <TextBlock Text="{Binding TopCategory}" 
                              FontSize="24"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              TextTrimming="CharacterEllipsis"
                              Margin="0,8,0,0"/>
                    <TextBlock Text="€1,234.50" 
                              FontSize="14"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Margin="0,4,0,0"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- ========== FILTERS & SEARCH ========== -->
        <Grid Grid.Row="2" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box with Icon -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <TextBox x:Name="SearchTextBox"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Height="40"
                        Padding="35,0,12,0"
                        VerticalContentAlignment="Center"
                        FontSize="14"
                        Foreground="#0A0A0A"
                        BorderBrush="#E5E7EB"
                        materialDesign:HintAssist.Hint="Search expenses..."
                        materialDesign:HintAssist.Foreground="#737373"
                        materialDesign:HintAssist.IsFloating="False"
                        materialDesign:TextFieldAssist.TextFieldCornerRadius="10"
                        materialDesign:TextFieldAssist.UnderlineBrush="#4A4A4A"
                        FocusVisualStyle="{x:Null}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                            <Style.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="#4A4A4A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <materialDesign:PackIcon Kind="Magnify"
                                        Width="18"
                                        Height="18"
                                        Foreground="#737373"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Margin="12,0,0,0"
                                        IsHitTestVisible="False"/>
            </Grid>

            <!-- Category Dropdown -->
            <ComboBox Grid.Column="1"
                     Style="{StaticResource CleanComboBox}"
                     ItemContainerStyle="{StaticResource CleanComboBoxItem}"
                     Height="40"
                     FontSize="13"
                     Padding="12,8"
                     Background="#FFFFFF"
                     BorderBrush="#E5E7EB"
                     VerticalContentAlignment="Center"
                     materialDesign:TextFieldAssist.TextFieldCornerRadius="10"
                     Margin="0,0,12,0">
                <ComboBoxItem Content="All Categories" IsSelected="True"/>
                <ComboBoxItem Content="Food &amp; Dining"/>
                <ComboBoxItem Content="Transportation"/>
                <ComboBoxItem Content="Shopping"/>
                <ComboBoxItem Content="Entertainment"/>
                <ComboBoxItem Content="Utilities"/>
                <ComboBoxItem Content="Education"/>
                <ComboBoxItem Content="Healthcare"/>
                <ComboBoxItem Content="Others"/>
            </ComboBox>

            <!-- Payment Method Dropdown -->
            <ComboBox Grid.Column="2"
                     Style="{StaticResource CleanComboBox}"
                     ItemContainerStyle="{StaticResource CleanComboBoxItem}"
                     Height="40"
                     FontSize="13"
                     Padding="12,8"
                     Background="#FFFFFF"
                     BorderBrush="#E5E7EB"
                     VerticalContentAlignment="Center"
                     materialDesign:TextFieldAssist.TextFieldCornerRadius="10"
                     Margin="0,0,12,0">
                <ComboBoxItem Content="All Methods" IsSelected="True"/>
                <ComboBoxItem Content="Cash"/>
                <ComboBoxItem Content="Credit Card"/>
                <ComboBoxItem Content="Debit Card"/>
                <ComboBoxItem Content="Digital Wallet"/>
            </ComboBox>

            <!-- Action Menu Button -->
            <Button Grid.Column="3"
                   Style="{StaticResource OutlinedButtonNoBorder}"
                   Width="37"
                   Height="37"
                   Padding="0"
                   VerticalAlignment="Center"
                   BorderBrush="#E5E7EB"
                   materialDesign:ButtonAssist.CornerRadius="10"
                   Click="FilterButton_Click">
                <TextBlock Text="⋮" FontSize="16" Foreground="#737373" FontWeight="Normal" VerticalAlignment="Center"/>
                <Button.ContextMenu>
                    <ContextMenu Style="{StaticResource MinimalContextMenu}">
                        <MenuItem Header="Edit Expense" 
                                 Command="{Binding EditExpenseCommand}"
                                 Style="{StaticResource MinimalMenuItem}">
                            <MenuItem.Icon>
                                <TextBlock Text="✎" FontSize="14" Foreground="#0A0A0A"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Delete Expense" 
                                 Command="{Binding DeleteExpenseCommand}"
                                 Style="{StaticResource MinimalMenuItem}">
                            <MenuItem.Icon>
                                <TextBlock Text="🗑" FontSize="14" Foreground="#EF4444"/>
                            </MenuItem.Icon>
                            <MenuItem.Foreground>
                                <SolidColorBrush Color="#EF4444"/>
                            </MenuItem.Foreground>
                        </MenuItem>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <!-- ========== EXPENSES LIST ========== -->
        <materialDesign:Card Grid.Row="3" 
                            Margin="0,0,0,16" 
                            Padding="20"
                            Effect="{StaticResource DashboardCardShadow}"
                            UniformCornerRadius="8"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            materialDesign:ElevationAssist.Elevation="Dp0">
            <DataGrid 
                         ItemsSource="{Binding Expenses}" 
                         SelectedItem="{Binding SelectedExpense}"
                         IsReadOnly="True"
                         Style="{StaticResource ModernDataGrid}"
                         RowStyle="{StaticResource ModernDataGridRow}"
                         ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                         CellStyle="{StaticResource ModernDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='MMM d, yyyy'}" 
                                          Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}" 
                                          Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" 
                                          Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}" 
                                          Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=€{0:N2}}" 
                                          Width="*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernDataGridColumnHeader}">
                                    <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#171717"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>

                </DataGrid>
        </materialDesign:Card>


    </Grid>
</Window>
